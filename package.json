{
  "name": "nanospy",
  "version": "2.0.0",
  "description": "Spy and mock methods in tests with great TypeScript support",
  "keywords": [
    "method",
    "mock",
    "spy",
    "typescript"
  ],
  "license": "MIT",
  "author": "Andrey Sitnik <andrey@sitnik.es>",
  "repository": "ai/nanospy",
  "sideEffects": false,
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test:lint": "oxlint",
    "test:coverage": "pnpm bnt --coverage 100 --coverage-exclude '**/*.test.ts'",
    "test:types": "check-dts",
    "unit": "node ./test/simple.js",
    "test": "pnpm run /^test:/"
  },
  "devDependencies": {
    "@logux/oxc-configs": "^0.4.0",
    "@types/node": "^25.9.3",
    "actions-up": "^1.14.3",
    "better-node-test": "^0.8.4",
    "check-dts": "^1.0.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^8.0.0 || ^10.0.0 || ^12.0.0 || ^14.0.0 || ^16.0.0 || ^18.0.0 || ^20.0.0 || ^22.0.0 || ^24.0.0 || >=26.0.0"
  }
}
